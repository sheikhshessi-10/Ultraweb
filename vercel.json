{
  "version": 2,
  "name": "ultraweb",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "teams.html", "use": "@vercel/static" },
    { "src": "ultra-logo-icon.png", "use": "@vercel/static" },
    { "src": "ultra-hero.mp4", "use": "@vercel/static" },
    { "src": "images/p1.png", "use": "@vercel/static" },
    { "src": "images/p3.png", "use": "@vercel/static" },
    { "src": "images/p4.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/teams", "dest": "/teams.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/ultra-hero.mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Accept-Ranges", "value": "bytes" }
      ]
    }
  ]
}
